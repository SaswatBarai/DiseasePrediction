\@writefile{toc}{\contentsline {subsection}{\numberline {10.1}Model Accuracy Comparison}{18}{subsection.10.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Classification performance of all four models on the held-out test set (985 samples, stratified 80/20 split). All metrics are macro-averaged across 41 disease classes, treating each class equally regardless of sample count. Accuracy = fraction of correctly classified samples. Precision = mean across classes of true positives / (true positives + false positives). Recall = mean across classes of true positives / (true positives + false negatives). F1 = harmonic mean of precision and recall. The Stacking Ensemble~\cite  {wolpert1992} achieves the highest accuracy (93.50\%), outperforming the Decision Tree~\cite  {quinlan1986} baseline by \textbf  {+7.92 percentage points}. Confusion matrices for each model are presented in Figures~\ref {fig:cmdt}--\ref {fig:cmstack}. All experiments were run with \texttt  {random\_state=42} for full reproducibility~\cite  {pedregosa2011}.}}{18}{table.caption.8}\protected@file@percent }
\newlabel{tab:results}{{3}{18}{Classification performance of all four models on the held-out test set (985 samples, stratified 80/20 split). All metrics are macro-averaged across 41 disease classes, treating each class equally regardless of sample count. Accuracy = fraction of correctly classified samples. Precision = mean across classes of true positives / (true positives + false positives). Recall = mean across classes of true positives / (true positives + false negatives). F1 = harmonic mean of precision and recall. The Stacking Ensemble~\cite {wolpert1992} achieves the highest accuracy (93.50\%), outperforming the Decision Tree~\cite {quinlan1986} baseline by \textbf {+7.92 percentage points}. Confusion matrices for each model are presented in Figures~\ref {fig:cmdt}--\ref {fig:cmstack}. All experiments were run with \texttt {random\_state=42} for full reproducibility~\cite {pedregosa2011}}{table.caption.8}{}}
