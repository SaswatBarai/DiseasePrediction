\@writefile{toc}{\contentsline {subsection}{\numberline {11.1}What the Numbers Actually Mean}{21}{subsection.11.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Normalised confusion matrix --- XGBoost~\cite  {chen2016xgboost} (100 rounds, \texttt  {lr=0.1}), accuracy \textbf  {91.47\%}. Sequential residual correction~\cite  {friedman2001} improves over the Decision Tree but underperforms Random Forest by 1.83 pt, as gradient boosting amplifies noise from the 50\% dropout step. Seaborn~\cite  {waskom2021seaborn} (Cell~17, Appendix).}}{22}{figure.caption.12}\protected@file@percent }
\newlabel{fig:cmxgb}{{7}{22}{Normalised confusion matrix --- XGBoost~\cite {chen2016xgboost} (100 rounds, \texttt {lr=0.1}), accuracy \textbf {91.47\%}. Sequential residual correction~\cite {friedman2001} improves over the Decision Tree but underperforms Random Forest by 1.83 pt, as gradient boosting amplifies noise from the 50\% dropout step. Seaborn~\cite {waskom2021seaborn} (Cell~17, Appendix)}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {11.2}What Works Well and What Does Not}{22}{subsection.11.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Normalised confusion matrix --- Stacking Ensemble~\cite  {wolpert1992} (DT + RF + XGB base learners, LR meta-learner, \texttt  {passthrough=True}, 5-fold CV), accuracy \textbf  {93.50\%} --- the sharpest diagonal across all four models. The +0.20 pt gain over Random Forest reflects the meta-learner correcting cases where all three base models simultaneously output high-confidence wrong predictions. Seaborn~\cite  {waskom2021seaborn} (Cell~17, Appendix).}}{23}{figure.caption.13}\protected@file@percent }
\newlabel{fig:cmstack}{{8}{23}{Normalised confusion matrix --- Stacking Ensemble~\cite {wolpert1992} (DT + RF + XGB base learners, LR meta-learner, \texttt {passthrough=True}, 5-fold CV), accuracy \textbf {93.50\%} --- the sharpest diagonal across all four models. The +0.20 pt gain over Random Forest reflects the meta-learner correcting cases where all three base models simultaneously output high-confidence wrong predictions. Seaborn~\cite {waskom2021seaborn} (Cell~17, Appendix)}{figure.caption.13}{}}
