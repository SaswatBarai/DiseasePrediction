\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Bar chart comparing the test-set accuracy of the four classifiers described in Section~\ref {sec:methodology} (see also Table~\ref {tab:results}). Each bar is annotated with its exact accuracy value. The Stacking Ensemble (93.50\%) leads, followed closely by Random Forest~\cite  {breiman2001} (93.30\%), XGBoost~\cite  {chen2016xgboost} (91.47\%), and the Decision Tree~\cite  {quinlan1986} baseline (85.58\%). The narrow 0.20-point gap between the Stacking Ensemble and Random Forest reflects the marginal but consistent gain from the Logistic Regression meta-learner's ability to recover cases where all three base models are simultaneously incorrect. Generated using Matplotlib~\cite  {hunter2007matplotlib} (see Cell~19 in the Appendix).}}{19}{figure.caption.9}\protected@file@percent }
\newlabel{fig:modelcomp}{{4}{19}{Bar chart comparing the test-set accuracy of the four classifiers described in Section~\ref {sec:methodology} (see also Table~\ref {tab:results}). Each bar is annotated with its exact accuracy value. The Stacking Ensemble (93.50\%) leads, followed closely by Random Forest~\cite {breiman2001} (93.30\%), XGBoost~\cite {chen2016xgboost} (91.47\%), and the Decision Tree~\cite {quinlan1986} baseline (85.58\%). The narrow 0.20-point gap between the Stacking Ensemble and Random Forest reflects the marginal but consistent gain from the Logistic Regression meta-learner's ability to recover cases where all three base models are simultaneously incorrect. Generated using Matplotlib~\cite {hunter2007matplotlib} (see Cell~19 in the Appendix)}{figure.caption.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.2}Confusion Matrices}{19}{subsection.10.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {10.3}Feature Importance}{19}{subsection.10.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Normalised confusion matrix --- Decision Tree~\cite  {quinlan1986}, accuracy \textbf  {85.58\%} (985 test samples). The noisier diagonal reflects overfitting on the 50\% dropout noise. The hepatitis cluster (B/C/D/E) produces the most off-diagonal mass, as their symptom profiles are clinically indistinguishable without laboratory tests. Seaborn~\cite  {waskom2021seaborn} (Cell~15, Appendix).}}{20}{figure.caption.10}\protected@file@percent }
\newlabel{fig:cmdt}{{5}{20}{Normalised confusion matrix --- Decision Tree~\cite {quinlan1986}, accuracy \textbf {85.58\%} (985 test samples). The noisier diagonal reflects overfitting on the 50\% dropout noise. The hepatitis cluster (B/C/D/E) produces the most off-diagonal mass, as their symptom profiles are clinically indistinguishable without laboratory tests. Seaborn~\cite {waskom2021seaborn} (Cell~15, Appendix)}{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Top 20 feature importance scores from the Random Forest~\cite  {breiman2001} base learner (200 estimators, \texttt  {random\_state=42}), measured as mean decrease in Gini impurity~\cite  {breiman1984cart} across all splits in all trees. Jaundice-cluster symptoms (\textit  {yellowing of eyes}, \textit  {dark urine}) dominate, followed by febrile-illness markers and --- critically --- the engineered \textbf  {age feature at rank 5 (0.035)}, validating the epidemiological prior encoding. The importance ordering is consistent with established clinical diagnostic hierarchies. Generated using Seaborn~\cite  {waskom2021seaborn} (Cell~20 in the Appendix).}}{20}{figure.caption.14}\protected@file@percent }
\newlabel{fig:featimport}{{9}{20}{Top 20 feature importance scores from the Random Forest~\cite {breiman2001} base learner (200 estimators, \texttt {random\_state=42}), measured as mean decrease in Gini impurity~\cite {breiman1984cart} across all splits in all trees. Jaundice-cluster symptoms (\textit {yellowing of eyes}, \textit {dark urine}) dominate, followed by febrile-illness markers and --- critically --- the engineered \textbf {age feature at rank 5 (0.035)}, validating the epidemiological prior encoding. The importance ordering is consistent with established clinical diagnostic hierarchies. Generated using Seaborn~\cite {waskom2021seaborn} (Cell~20 in the Appendix)}{figure.caption.14}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Normalised confusion matrix --- Random Forest~\cite  {breiman2001} (200 trees), accuracy \textbf  {93.30\%}. Most classes reach recall $\geq 0.90$. Residual confusions concentrate in the hepatitis cluster and between Dengue and Malaria. The +7.72 pt gain over the Decision Tree stems from variance reduction via majority voting across 200 independently trained trees. Seaborn~\cite  {waskom2021seaborn} (Cell~16, Appendix).}}{21}{figure.caption.11}\protected@file@percent }
\newlabel{fig:cmrf}{{6}{21}{Normalised confusion matrix --- Random Forest~\cite {breiman2001} (200 trees), accuracy \textbf {93.30\%}. Most classes reach recall $\geq 0.90$. Residual confusions concentrate in the hepatitis cluster and between Dengue and Malaria. The +7.72 pt gain over the Decision Tree stems from variance reduction via majority voting across 200 independently trained trees. Seaborn~\cite {waskom2021seaborn} (Cell~16, Appendix)}{figure.caption.11}{}}
\@writefile{toc}{\contentsline {section}{\numberline {11}Discussion}{21}{section.11}\protected@file@percent }
