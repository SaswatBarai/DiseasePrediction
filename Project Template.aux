\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Software tools and libraries used in the Disease Prediction System pipeline. All libraries are open-source and freely available. Scikit-learn~\cite  {pedregosa2011} provides the Decision Tree, Random Forest, StackingClassifier, preprocessing utilities, and evaluation metrics. XGBoost~\cite  {chen2016xgboost} is used as a standalone gradient boosting base learner. Matplotlib~\cite  {hunter2007matplotlib} and Seaborn~\cite  {waskom2021seaborn} produce all visualisations in Section~\ref {sec:results}. The complete reproducible implementation is available in the Appendix.}}{16}{table.caption.7}\protected@file@percent }
\newlabel{tab:tech}{{2}{16}{Software tools and libraries used in the Disease Prediction System pipeline. All libraries are open-source and freely available. Scikit-learn~\cite {pedregosa2011} provides the Decision Tree, Random Forest, StackingClassifier, preprocessing utilities, and evaluation metrics. XGBoost~\cite {chen2016xgboost} is used as a standalone gradient boosting base learner. Matplotlib~\cite {hunter2007matplotlib} and Seaborn~\cite {waskom2021seaborn} produce all visualisations in Section~\ref {sec:results}. The complete reproducible implementation is available in the Appendix}{table.caption.7}{}}
