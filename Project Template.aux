\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Summary of the Disease Symptom Prediction Dataset~\cite  {itachi2020}. The dataset is sourced from two CSV files: \texttt  {disease\_raw.csv} (patient symptom records) and \texttt  {symptom\_severity.csv} (clinical severity weights 1--7 per symptom). After severity-weighted vectorisation, 50\% symptom dropout, age-feature augmentation, and zero-variance filtering, the final model-ready matrix contains \textbf  {135 features} across \textbf  {4,925 records} spanning \textbf  {41 disease classes}. The 80/20 stratified split (Section~\ref {subsec:preprocess}) ensures all 41 classes are proportionally represented in both training and evaluation subsets.}}{8}{table.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:dataset}{{1}{8}{Summary of the Disease Symptom Prediction Dataset~\cite {itachi2020}. The dataset is sourced from two CSV files: \texttt {disease\_raw.csv} (patient symptom records) and \texttt {symptom\_severity.csv} (clinical severity weights 1--7 per symptom). After severity-weighted vectorisation, 50\% symptom dropout, age-feature augmentation, and zero-variance filtering, the final model-ready matrix contains \textbf {135 features} across \textbf {4,925 records} spanning \textbf {41 disease classes}. The 80/20 stratified split (Section~\ref {subsec:preprocess}) ensures all 41 classes are proportionally represented in both training and evaluation subsets}{table.caption.2}{}}
