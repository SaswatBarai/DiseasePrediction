\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Pearson correlation heatmap of the top 20 most frequently occurring symptoms (by total severity weight) across all 4,925 patient records. Cell values represent the Pearson correlation coefficient between each symptom pair; red shading indicates positive co-occurrence and blue indicates inverse co-occurrence. Notable clusters include \textit  {yellowing\_of\_eyes}, \textit  {dark\_urine}, and \textit  {loss\_of\_appetite} (upper-left block, $r \approx 0.6$--$0.8$), which correspond to hepatitis-related conditions, and the \textit  {sweating}/\textit  {chills}/\textit  {high\_fever} cluster associated with acute febrile illnesses. These co-occurrence patterns motivate the use of tree-based models~\cite  {breiman2001}, which naturally capture feature interactions without explicit encoding. Generated using Seaborn~\cite  {waskom2021seaborn} (see Cell~9 in the Appendix).}}{11}{figure.caption.3}\protected@file@percent }
\newlabel{fig:heatmap}{{1}{11}{Pearson correlation heatmap of the top 20 most frequently occurring symptoms (by total severity weight) across all 4,925 patient records. Cell values represent the Pearson correlation coefficient between each symptom pair; red shading indicates positive co-occurrence and blue indicates inverse co-occurrence. Notable clusters include \textit {yellowing\_of\_eyes}, \textit {dark\_urine}, and \textit {loss\_of\_appetite} (upper-left block, $r \approx 0.6$--$0.8$), which correspond to hepatitis-related conditions, and the \textit {sweating}/\textit {chills}/\textit {high\_fever} cluster associated with acute febrile illnesses. These co-occurrence patterns motivate the use of tree-based models~\cite {breiman2001}, which naturally capture feature interactions without explicit encoding. Generated using Seaborn~\cite {waskom2021seaborn} (see Cell~9 in the Appendix)}{figure.caption.3}{}}
