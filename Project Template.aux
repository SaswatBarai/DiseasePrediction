\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Four illustrative records from the processed feature matrix, showing severity-weighted symptom columns (integer scale 0--7 from~\cite  {itachi2020}; 0 = symptom absent or zeroed by dropout), the epidemiologically sampled \textit  {age} column (Section~\ref {subsec:preprocess}), and the target \textit  {prognosis} label. The full matrix contains 135 such feature columns after zero-variance filtering (see Table~\ref {tab:dataset}). Note that Dengue (row 3) shows \textit  {itching} at severity 7 but \textit  {skin\_rash} at 0 --- an example of the 50\% dropout masking a co-occurring symptom, simulating real incomplete clinical reporting.}}{28}{table.caption.17}\protected@file@percent }
\newlabel{tab:sample}{{5}{28}{Four illustrative records from the processed feature matrix, showing severity-weighted symptom columns (integer scale 0--7 from~\cite {itachi2020}; 0 = symptom absent or zeroed by dropout), the epidemiologically sampled \textit {age} column (Section~\ref {subsec:preprocess}), and the target \textit {prognosis} label. The full matrix contains 135 such feature columns after zero-variance filtering (see Table~\ref {tab:dataset}). Note that Dengue (row 3) shows \textit {itching} at severity 7 but \textit {skin\_rash} at 0 --- an example of the 50\% dropout masking a co-occurring symptom, simulating real incomplete clinical reporting}{table.caption.17}{}}
